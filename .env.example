# ── Database ───────────────────────────────────────────────────────────────────
ATTRIBUTIONOPS_DB_PATH=data/dummy/attributionops_demo.sqlite
# Match the reporting timezone configured in the source Hyros account.
REPORT_TIMEZONE=Etc/GMT+6

# Tracking pixel
TRACKING_DOMAIN=http://localhost:8000
SITE_TOKEN=your-site-token
GOOGLE_ADS_SCRIPT_TOKEN=your-private-google-ads-script-token
GOOGLE_ADS_SYNC_MODE=api
# Direct Google Ads API sync also reconciles campaign-only Performance Max /
# Smart / Demand Gen spend. Google Ads Script pushes reconcile supplied
# campaign totals automatically regardless of this setting.
GOOGLE_INCLUDE_CAMPAIGN_ADJUSTMENTS=true

# Optional Stape server-side GTM endpoint for Google Ads purchase pushback.
# Example: https://wnczugry.usv.stape.io
STAPE_ENDPOINT=

# ── Meta (Facebook) Ads API ────────────────────────────────────────────────────
META_ACCESS_TOKEN=your_meta_system_user_access_token
META_APP_SECRET=
META_PIXEL_ID=
META_AD_ACCOUNT_ID=your_meta_ad_account_id
# Reconcile campaign-only Meta spend (Advantage+/automated campaigns report no
# ad-level Insights rows; without this their cost is silently dropped).
META_INCLUDE_CAMPAIGN_ADJUSTMENTS=true

# ── Google Ads API ─────────────────────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_google_ads_refresh_token
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_API_VERSION=v24
GOOGLE_ADS_CUSTOMER_ID=your_google_ads_customer_id

# ── TikTok Ads API ────────────────────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=
TIKTOK_APP_ID=
TIKTOK_SECRET=
TIKTOK_ADVERTISER_ID=
TIKTOK_PIXEL_ID=
# TikTok's report API does not return a currency per row; set the ad account's
# billing currency (e.g. USD) so TikTok spend rows are stamped with it.
TIKTOK_ACCOUNT_CURRENCY=

# ── Ad spend currency ──────────────────────────────────────────────────────────
# Currency all spend/revenue totals are reported in.
REPORT_CURRENCY=CAD
# Read-time FX conversion for spend stored in another billing currency.
# Format: "USD:1.40,EUR:1.55" — units of REPORT_CURRENCY per 1 source unit.
# Currencies without a configured rate stay unconverted and are surfaced in the
# spend_by_currency breakdown returned by ads_get_spend / the spend sync.
SPEND_FX_RATES=
STRIPE_RECURRING_AMOUNT_KEYS=
# One-time pre-window history used to distinguish new vs returning customers.
STRIPE_HISTORY_BACKFILL_DAYS=365

# ── Webhook Secrets ────────────────────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Dashboard Login (no registration) ─────────────────────────────────────────
AUTH_ENABLED=
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SECRET_KEY=
AUTH_SESSION_TTL_HOURS=
AUTH_COOKIE_SECURE=
